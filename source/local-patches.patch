+def _codex_account_fingerprint(access_token: str) -> str:
+    """Return a non-secret stable fingerprint for a Codex OAuth account.
+
+    The raw subject/email claim is never returned or stored. If the access
+    token shape changes and no stable identity claim is available, return an
+    empty string so dashboard login falls back to appending a new account.
+    """
+    try:
+        import base64
+        import hashlib
+
+        parts = str(access_token or "").split(".")
+        if len(parts) < 2:
+            return ""
+        payload = parts[1] + "=" * (-len(parts[1]) % 4)
+        claims = json.loads(base64.urlsafe_b64decode(payload.encode()).decode())
+        for key in ("sub", "https://api.openai.com/auth", "email", "preferred_username"):
+            value = claims.get(key)
+            if isinstance(value, dict):
+                for nested_key in ("user_id", "account_id", "id", "email"):
+                    nested = value.get(nested_key)
+                    if isinstance(nested, str) and nested.strip():
+                        raw = f"{key}:{nested.strip()}"
+                        return "sha256:" + hashlib.sha256(raw.encode()).hexdigest()
+            if isinstance(value, str) and value.strip():
+                raw = f"{key}:{value.strip()}"
+                return "sha256:" + hashlib.sha256(raw.encode()).hexdigest()
+    except Exception:
+        return ""
+    return ""
